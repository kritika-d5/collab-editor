# ── Local docker-compose ──────────────────────────────────
POSTGRES_USER=collab
POSTGRES_PASSWORD=collab_secret
POSTGRES_DB=collabdb

# ── Backend ─────────────────────────────────────────────
DATABASE_URL=postgresql://collab:collab_secret@postgres:5432/collabdb
REDIS_URL=redis://redis:6379
JWT_SECRET=change_this_to_a_long_random_string
JWT_REFRESH_SECRET=change_this_too
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── Frontend (local dev — Vite proxy handles /api) ──────
VITE_API_URL=
VITE_WS_URL=

# ── Railway production examples ───────────────────────────
# DATABASE_URL=          # auto-injected by Railway Postgres plugin
# REDIS_URL=             # auto-injected by Railway Redis plugin
# JWT_SECRET=            # openssl rand -base64 48
# JWT_REFRESH_SECRET=    # openssl rand -base64 48
# NODE_ENV=production
# PORT=4000              # Railway sets PORT automatically; 4000 is fine as fallback
# FRONTEND_URL=https://your-frontend.up.railway.app
# VITE_API_URL=https://your-backend.up.railway.app
# VITE_WS_URL=wss://your-backend.up.railway.app
